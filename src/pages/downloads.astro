---
import MainGridLayout from "../layouts/MainGridLayout.astro";
import { Icon } from "astro-icon/components";

interface FileInfo {
  name: string;
  url: string;
  description?: string;
  size?: string;
}

interface FileCategory {
  name: string;
  files: FileInfo[];
}

async function getFileCategories(): Promise<FileCategory[]> {
  const categories: FileCategory[] = [];
  const files = import.meta.glob<{ default: FileInfo }>('/src/files/**/*.json', { eager: true });
  const categoryMap = new Map<string, FileInfo[]>();

  Object.entries(files).forEach(([path, module]) => {
    const match = path.match(/\/src\/files\/([^\/]+)\/[^\/]+\.json$/);
    if (match && module?.default) {
      const categoryName = match[1];
      if (!categoryMap.has(categoryName)) {
        categoryMap.set(categoryName, []);
      }
      categoryMap.get(categoryName)!.push(module.default);
    }
  });

  categoryMap.forEach((files, name) => {
    categories.push({ name, files });
  });

  return categories.sort((a, b) => a.name.localeCompare(b.name));
}

const categories = await getFileCategories();
const totalFiles = categories.reduce((sum, cat) => sum + cat.files.length, 0);
---

<MainGridLayout title="文件" description="文件下载中心">
  <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
    <div class="card-base z-10 px-4 md:px-6 py-5 relative w-full">
      <!-- 标题 -->
      <div class="flex items-center justify-between mb-4">
        <div class="flex items-center gap-2">
          <Icon name="material-symbols:folder-open" class="text-2xl text-[var(--primary)]" />
          <h1 class="text-xl font-bold text-neutral-900 dark:text-neutral-100">文件索引</h1>
        </div>
        <span class="text-xs text-neutral-500 dark:text-neutral-400">
          {categories.length} 个文件夹 · {totalFiles} 个文件
        </span>
      </div>

      <p class="text-sm text-neutral-500 dark:text-neutral-400 mb-4">这里展示了本站托管的各项公开资源，你可以点击查看并下载。</p>

      <!-- 路径导航栏 -->
      <div class="flex items-center gap-2 mb-4 px-3 py-2 bg-neutral-100 dark:bg-neutral-800/50 rounded-lg text-sm">
        <button id="btn-back" class="hidden flex-shrink-0 items-center gap-1 px-2 py-1 rounded hover:bg-neutral-200 dark:hover:bg-neutral-700 transition-colors text-neutral-600 dark:text-neutral-400">
          <Icon name="material-symbols:arrow-back" class="w-4 h-4" />
          <span>返回</span>
        </button>
        <button id="breadcrumb-root" class="flex items-center gap-1 text-neutral-600 dark:text-neutral-400 hover:text-[var(--primary)] transition-colors">
          <Icon name="material-symbols:home" class="w-4 h-4" />
          <span>根目录</span>
        </button>
        <span id="breadcrumb-category" class="hidden items-center gap-1">
          <Icon name="material-symbols:chevron-right" class="w-4 h-4 text-neutral-400" />
          <button id="category-link" class="flex items-center gap-1 text-neutral-800 dark:text-neutral-200 hover:text-[var(--primary)] transition-colors">
            <Icon name="material-symbols:folder" class="w-4 h-4 text-[var(--primary)]" />
            <span id="category-name"></span>
          </button>
        </span>
      </div>

      <!-- 内容区域 -->
      <div id="content-container" class="border border-neutral-200 dark:border-neutral-700 rounded-lg overflow-hidden relative">
        <!-- 服务端渲染的初始内容 -->
        <div id="root-content">
          {categories.length === 0 && (
            <div class="text-center py-12 text-neutral-400 dark:text-neutral-600">
              <Icon name="material-symbols:folder-off" class="text-5xl mb-4 opacity-50 mx-auto" />
              <p class="text-sm">暂无文件资源</p>
            </div>
          )}
          
          {categories.map((category, index) => (
            <div 
              class="folder-row flex items-center gap-3 px-4 py-3 cursor-pointer border-b border-neutral-100 dark:border-neutral-800 hover:bg-neutral-50 dark:hover:bg-neutral-800/50 transition-colors"
              data-category={category.name}
              style={`animation: fadeIn 0.3s ease ${index * 0.05}s both`}
            >
              <Icon name="material-symbols:folder" class="w-5 h-5 text-[var(--primary)] flex-shrink-0" />
              <span class="flex-1 font-medium text-neutral-800 dark:text-neutral-200 truncate">{category.name}</span>
            </div>
          ))}
        </div>
        
        <!-- 子目录内容（隐藏） -->
        <div id="sub-content" class="hidden">
          <div id="file-list"></div>
        </div>
      </div>

      <!-- 统计信息 -->
      <div class="mt-5 pt-4 border-t border-neutral-100 dark:border-neutral-800 text-center">
        <p class="text-xs text-neutral-400 dark:text-neutral-500">
          共 {categories.length} 个分类，{totalFiles} 个文件
        </p>
      </div>

      <!-- 免责声明 -->
      <div class="mt-6 text-center">
        <p class="text-xs text-neutral-400 dark:text-neutral-500">
          所有文件均来自网络，仅供学习交流使用，风险自担
        </p>
      </div>
    </div>
  </div>
</MainGridLayout>

<style>
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateX(-10px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }
  
  .folder-row {
    transition: background-color 0.15s ease;
  }
  
  .folder-row:hover {
    background-color: rgb(243 244 246);
  }
  
  :global(.dark) .folder-row:hover {
    background-color: rgb(38 38 38 / 0.5);
  }
  
  .file-item {
    transition: background-color 0.15s ease;
  }
  
  .file-item:hover {
    background-color: rgb(243 244 246);
  }
  
  :global(.dark) .file-item:hover {
    background-color: rgb(38 38 38 / 0.7);
  }
  
  #breadcrumb-root:hover,
  #category-link:hover {
    background-color: rgb(229 231 235);
    border-radius: 4px;
  }
  
  :global(.dark) #breadcrumb-root:hover,
  :global(.dark) #category-link:hover {
    background-color: rgb(75 75 75);
  }
  
  .content-transition {
    animation: slideIn 0.25s ease;
  }
  
  @keyframes slideIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<script define:vars={{ categories: JSON.parse(JSON.stringify(categories)) }}>
  const rootContent = document.getElementById('root-content');
  const subContent = document.getElementById('sub-content');
  const fileList = document.getElementById('file-list');
  const btnBack = document.getElementById('btn-back');
  const breadcrumbRoot = document.getElementById('breadcrumb-root');
  const breadcrumbCategory = document.getElementById('breadcrumb-category');
  const categoryLink = document.getElementById('category-link');
  const categoryNameSpan = document.getElementById('category-name');
  
  let currentCategory = null;
  
  function showRoot() {
    currentCategory = null;
    rootContent.classList.remove('hidden');
    subContent.classList.add('hidden');
    subContent.classList.remove('content-transition');
    
    breadcrumbCategory.classList.add('hidden');
    breadcrumbCategory.classList.remove('flex');
    btnBack.classList.add('hidden');
    btnBack.classList.remove('flex');
    
    window.history.replaceState(null, '', window.location.pathname.replace(/\/+$/, '') + '/');
  }
  
  function showCategory(categoryName) {
    const category = categories.find(c => c.name === categoryName);
    if (!category) return;
    
    currentCategory = categoryName;
    
    let html = '';
    category.files.forEach((file, index) => {
      html += `
        <a href="${file.url}" 
           target="_blank" 
           rel="noopener noreferrer"
           class="file-item flex items-center gap-3 px-4 py-2.5 border-b border-neutral-100 dark:border-neutral-800 last:border-b-0"
           style="animation: fadeIn 0.2s ease ${index * 0.03}s both">
          <svg class="w-4 h-4 text-neutral-400 dark:text-neutral-500 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/>
            <path d="M14 2v4a2 2 0 0 0 2 2h4"/>
          </svg>
          <span class="flex-1 text-neutral-700 dark:text-neutral-300 hover:text-[var(--primary)] transition-colors truncate">
            ${file.name}
          </span>
        </a>
      `;
    });
    
    fileList.innerHTML = html;
    
    rootContent.classList.add('hidden');
    subContent.classList.remove('hidden');
    subContent.classList.add('content-transition');
    
    breadcrumbCategory.classList.remove('hidden');
    breadcrumbCategory.classList.add('flex');
    categoryNameSpan.textContent = categoryName;
    btnBack.classList.remove('hidden');
    btnBack.classList.add('flex');
    
    window.location.hash = '/' + encodeURIComponent(categoryName);
  }
  
  document.querySelectorAll('.folder-row').forEach(row => {
    row.addEventListener('click', () => {
      const categoryName = row.getAttribute('data-category');
      showCategory(categoryName);
    });
  });
  
  btnBack.addEventListener('click', () => {
    showRoot();
  });
  
  window.addEventListener('hashchange', () => {
    const hash = window.location.hash;
    if (hash && hash.startsWith('#/')) {
      const categoryName = decodeURIComponent(hash.slice(2));
      if (categoryName !== currentCategory) {
        showCategory(categoryName);
      }
    } else if (currentCategory) {
      showRoot();
    }
  });
  
  function init() {
    // 绑定根目录点击事件
    breadcrumbRoot.addEventListener('click', () => {
      showRoot();
    });
    
    // 绑定分类名点击事件
    categoryLink.addEventListener('click', () => {
      // 点击分类名，重新进入该分类（相当于刷新状态）
      if (currentCategory) {
        showCategory(currentCategory);
      }
    });
    
    const hash = window.location.hash;
    if (hash && hash.startsWith('#/')) {
      const categoryName = decodeURIComponent(hash.slice(2));
      if (categories.find(c => c.name === categoryName)) {
        showCategory(categoryName);
      }
    }
  }
  
  init();
</script>
