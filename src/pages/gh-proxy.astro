---
import MainGridLayout from "../layouts/MainGridLayout.astro";
import { Icon } from "astro-icon/components";

export const prerender = true;
---
<MainGridLayout title="GitHub 反代" description="GitHub 反代链接生成器">
    <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
        <div class="card-base z-10 px-6 md:px-9 py-6 relative w-full">
            <div class="flex items-center gap-2 mb-6">
                <Icon name="mdi:github" class="text-2xl text-[var(--primary)]" />
                <h1 class="text-2xl font-bold text-neutral-900 dark:text-neutral-100">GitHub 反代链接生成器</h1>
            </div>
            <p class="text-neutral-500 dark:text-neutral-400 mb-6">输入 GitHub 原始链接，生成 gh-proxy.com 反代加速链接</p>

            <div class="space-y-5">
                <div>
                    <label for="gh-input" class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-2">原始链接</label>
                    <div class="flex gap-2">
                        <input id="gh-input" type="url" placeholder="https://github.com/user/repo/releases/download/v1.0/file.zip"
                            class="flex-1 px-4 py-2.5 rounded-lg bg-neutral-100 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700 text-neutral-900 dark:text-neutral-100 placeholder-neutral-400 dark:placeholder-neutral-500 focus:outline-none focus:ring-2 focus:ring-[var(--primary)] focus:border-transparent transition-all" />
                    </div>
                </div>

                <div>
                    <label for="gh-output" class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-2">反代链接</label>
                    <div class="flex gap-2">
                        <input id="gh-output" type="text" readonly
                            class="flex-1 px-4 py-2.5 rounded-lg bg-neutral-100 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700 text-neutral-900 dark:text-neutral-100 placeholder-neutral-400 dark:placeholder-neutral-500 focus:outline-none" />
                    </div>
                </div>

                <div class="flex gap-3">
                    <button id="btn-copy"
                        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-[var(--primary)] text-white font-medium hover:opacity-90 active:scale-95 transition-all">
                        <Icon name="material-symbols:content-copy" class="text-lg" />
                        <span>一键复制</span>
                    </button>
                    <button id="btn-download"
                        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-neutral-200 dark:bg-neutral-700 text-neutral-900 dark:text-neutral-100 font-medium hover:opacity-90 active:scale-95 transition-all disabled:opacity-40 disabled:cursor-not-allowed" disabled>
                        <Icon name="material-symbols:download" class="text-lg" />
                        <span>一键下载</span>
                    </button>
                    <button id="btn-clear"
                        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-neutral-100 dark:bg-neutral-800 text-neutral-500 dark:text-neutral-400 font-medium hover:opacity-90 active:scale-95 transition-all">
                        <Icon name="material-symbols:close" class="text-lg" />
                        <span>清空</span>
                    </button>
                </div>

                <div id="toast" class="hidden fixed top-6 left-1/2 -translate-x-1/2 px-5 py-2.5 rounded-lg bg-green-500 text-white text-sm font-medium shadow-lg z-[9999] transition-all">
                    已复制到剪贴板
                </div>
            </div>
        </div>
    </div>
</MainGridLayout>

<script>
    const PROXY_PREFIX = "https://gh-proxy.com/";
    const input = document.getElementById("gh-input") as HTMLInputElement;
    const output = document.getElementById("gh-output") as HTMLInputElement;
    const btnCopy = document.getElementById("btn-copy") as HTMLButtonElement;
    const btnDownload = document.getElementById("btn-download") as HTMLButtonElement;
    const btnClear = document.getElementById("btn-clear") as HTMLButtonElement;
    const toast = document.getElementById("toast") as HTMLDivElement;

    function getProxyUrl(): string {
        const val = input.value.trim();
        if (!val) return "";
        return PROXY_PREFIX + val;
    }

    function updateOutput() {
        const proxyUrl = getProxyUrl();
        output.value = proxyUrl;
        btnDownload.disabled = !proxyUrl;
    }

    function showToast(msg: string, duration = 1500) {
        toast.textContent = msg;
        toast.classList.remove("hidden");
        setTimeout(() => {
            toast.classList.add("hidden");
        }, duration);
    }

    input.addEventListener("input", updateOutput);

    btnCopy.addEventListener("click", () => {
        const url = getProxyUrl();
        if (!url) {
            showToast("请先输入链接", 1500);
            return;
        }
        navigator.clipboard.writeText(url).then(() => {
            showToast("已复制到剪贴板");
        }).catch(() => {
            output.select();
            document.execCommand("copy");
            showToast("已复制到剪贴板");
        });
    });

    btnDownload.addEventListener("click", () => {
        const url = getProxyUrl();
        if (!url) return;
        window.open(url, "_blank");
    });

    btnClear.addEventListener("click", () => {
        input.value = "";
        output.value = "";
        btnDownload.disabled = true;
    });
</script>
