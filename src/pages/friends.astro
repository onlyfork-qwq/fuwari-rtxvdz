---
import GiscusWithCaptcha from "../components/misc/GiscusWithCaptcha.astro";
import friendsData from "../config/friends.json";
import MainGridLayout from "../layouts/MainGridLayout.astro";
import { Icon } from "astro-icon/components";

export const prerender = true;

// 从JSON文件加载友链数据
const friends = friendsData;
---
<MainGridLayout title="友链" description="友链">
    <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
        <div class="card-base z-10 px-6 md:px-9 py-6 relative w-full">
            <!-- 标题区域 -->
            <div class="flex items-center justify-between mb-6">
                <div class="flex items-center gap-2">
                    <Icon name="material-symbols:diversity-3" class="text-2xl text-[var(--primary)]" />
                    <h1 class="text-2xl font-bold text-neutral-900 dark:text-neutral-100">友链</h1>
                </div>
                <span class="px-3 py-1 rounded-full bg-[var(--primary)]/10 text-[var(--primary)] text-sm font-medium flex items-center gap-1">
                    <Icon name="material-symbols:group-rounded" class="text-base" />
                    {friends.length}
                </span>
            </div>
            <p class="text-neutral-500 dark:text-neutral-400 mb-6">遇见更多有趣的小伙伴</p>

            <!-- 友链卡片网格 -->
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                {friends.map((friend, index) => (
                    <a href={friend.url} target="_blank" rel="noopener noreferrer"
                       class="group block p-4 rounded-xl bg-neutral-50 dark:bg-neutral-800/50 hover:bg-white dark:hover:bg-neutral-800 hover:shadow-lg hover:shadow-neutral-200/50 dark:hover:shadow-neutral-900/50 hover:-translate-y-1 transition-all duration-300 ease-out"
                       style={`animation: fadeInUp 0.5s ease-out ${index * 0.05}s both`}>
                        <div class="flex items-center gap-3">
                            <!-- 头像 -->
                            <div class="w-12 h-12 rounded-full overflow-hidden bg-neutral-200 dark:bg-neutral-700 flex-shrink-0 ring-2 ring-transparent group-hover:ring-[var(--primary)]/30 transition-all duration-300">
                                <img src={friend.icon} alt={`${friend.name}的头像`} class="w-full h-full object-cover">
                            </div>
                            <!-- 信息 -->
                            <div class="flex-1 min-w-0">
                                <div class="font-semibold text-neutral-900 dark:text-neutral-100 group-hover:text-[var(--primary)] transition-colors duration-300 truncate">
                                    {friend.name}
                                </div>
                                <div class="text-sm text-neutral-500 dark:text-neutral-400 truncate">
                                    {friend.description}
                                </div>
                            </div>
                            <!-- 外链图标 -->
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-neutral-300 dark:text-neutral-600 group-hover:text-[var(--primary)] transition-colors duration-300 flex-shrink-0">
                                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                                <polyline points="15 3 21 3 21 9"></polyline>
                                <line x1="10" y1="14" x2="21" y2="3"></line>
                            </svg>
                        </div>
                    </a>
                ))}
            </div>

            <div class="mt-8 text-center">
                <p class="text-sm text-neutral-500 dark:text-neutral-400">你也想上榜？可以评论哦~或者提Pr</p>
            </div>
        </div>
    </div>

    <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative mt-4">
        <div class="card-base z-10 px-6 md:px-9 py-6 relative w-full">
             <GiscusWithCaptcha
                repo="onlyfork-qwq/pinglun"
                repoId="R_kgDOQfRWyg"
                category="Announcements"
                categoryId="DIC_kwDOQfRWys4CzL22"
                lang="zh-CN"
            />
        </div>
    </div>
</MainGridLayout>

<style>
    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>
