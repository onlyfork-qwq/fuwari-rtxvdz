---  
import WidgetLayout from "./WidgetLayout.astro";

interface Props {
	class?: string;
	style?: string;
}
const { class: className, style } = Astro.props;

const UMAMI_CONFIG = {
	enable: true,
	baseUrl: "https://u.0y.hk", // 你的统计地址
	shareId: "kXWWnu6L9txtK9PT", // 从Umami分享设置中获取
	timezone: "Asia/Shanghai",
};
---  
  
<WidgetLayout name="统计" id="umami-stats" class:list={[className]} {style}>  
    <div class="text-center py-2">  
        <div class="text-3xl font-bold text-neutral-900 dark:text-neutral-100" id="total-pageviews">-</div>  
        <div class="text-sm text-neutral-500 dark:text-neutral-400">总浏览量</div>  
    </div>  
    <div class="grid grid-cols-2 divide-x divide-neutral-200 dark:divide-neutral-700 text-center pt-2">  
        <div class="px-2">  
            <div class="text-xl font-bold text-neutral-900 dark:text-neutral-100" id="total-visits">-</div>  
            <div class="text-sm text-neutral-500 dark:text-neutral-400">访问数</div>  
        </div>  
        <div class="px-2">  
            <div class="text-xl font-bold text-neutral-900 dark:text-neutral-100" id="total-visitors">-</div>  
            <div class="text-sm text-neutral-500 dark:text-neutral-400">游客数</div>  
        </div>  
    </div>  
</WidgetLayout>  
  
<script define:vars={{ UMAMI_CONFIG }}>  
// ===== 完整移植自 public/js/umami-share.js =====  
((global) => {  
	const cacheKey = "umami-share-cache";  
	const cacheTTL = 3600_000; // 1h  
  
	async function fetchShareData(baseUrl, shareId) {  
		const cached = localStorage.getItem(cacheKey);  
		if (cached) {  
			try {  
				const parsed = JSON.parse(cached);  
				if (Date.now() - parsed.timestamp < cacheTTL) {  
					return parsed.value;  
				}  
			} catch {  
				localStorage.removeItem(cacheKey);  
			}  
		}  
		const res = await fetch(`${baseUrl}/api/share/${shareId}`);  
		if (!res.ok) {  
			throw new Error("获取 Umami 分享信息失败");  
		}  
		const data = await res.json();  
		localStorage.setItem(  
			cacheKey,  
			JSON.stringify({ timestamp: Date.now(), value: data }),  
		);  
		return data;  
	}  
  
	global.getUmamiShareData = (baseUrl, shareId) => {  
		if (!global.__umamiSharePromise) {  
			global.__umamiSharePromise = fetchShareData(baseUrl, shareId).catch(  
				(err) => {  
					delete global.__umamiSharePromise;  
					throw err;  
				},  
			);  
		}  
		return global.__umamiSharePromise;  
	};  
  
	global.clearUmamiShareCache = () => {  
		localStorage.removeItem(cacheKey);  
		delete global.__umamiSharePromise;  
	};  
  
	if (!global.__umamiDataCache) {  
		global.__umamiDataCache = new Map();  
	}  
  
	global.fetchUmamiStats = async (baseUrl, shareId, queryParams) => {  
		const statsCacheKey = `${baseUrl}|${shareId}|${JSON.stringify(queryParams)}`;  
  
		if (global.__umamiDataCache.has(statsCacheKey)) {  
			const data = global.__umamiDataCache.get(statsCacheKey);  
			return { ...data, _fromCache: true };  
		}  
  
		async function doFetch(isRetry = false) {  
			const { websiteId, token } = await global.getUmamiShareData(baseUrl, shareId);  
			const currentTimestamp = Date.now();  
			const params = new URLSearchParams({  
				startAt: 0,  
				endAt: currentTimestamp,  
				unit: "hour",  
				timezone: queryParams.timezone || "Asia/Shanghai",  
				compare: false,  
				...queryParams,  
			});  
  
			const statsUrl = `${baseUrl}/api/websites/${websiteId}/stats?${params.toString()}`;  
  
			const res = await fetch(statsUrl, {  
				headers: {  
					"x-umami-share-token": token,  
				},  
			});  
  
			if (!res.ok) {  
				if (res.status === 401 && !isRetry) {  
					global.clearUmamiShareCache();  
					return doFetch(true);  
				}  
				throw new Error("获取统计数据失败");  
			}  
  
			const data = await res.json();  
			global.__umamiDataCache.set(statsCacheKey, data);  
			return data;  
		}  
  
		return doFetch();  
	};  
})(window);  
  
// ===== UI 逻辑 =====  
  
function formatNumber(num) {  
	if (num >= 1000000) return (num / 1000000).toFixed(1) + 'M';  
	if (num >= 1000) return (num / 1000).toFixed(1) + 'K';  
	return num.toString();  
}  
  
async function loadStats() {  
	if (!UMAMI_CONFIG.enable) return;  
	try {  
		const data = await window.fetchUmamiStats(  
			UMAMI_CONFIG.baseUrl,  
			UMAMI_CONFIG.shareId,  
			{ timezone: UMAMI_CONFIG.timezone }  
		);  
  
		// Umami API 返回 { pageviews: { value: N }, visits: { value: N }, visitors: { value: N } }  
		document.getElementById('total-pageviews').textContent = formatNumber(data.pageviews?.value ?? 0);  
		document.getElementById('total-visits').textContent    = formatNumber(data.visits?.value ?? 0);  
		document.getElementById('total-visitors').textContent  = formatNumber(data.visitors?.value ?? 0);  
	} catch (error) {  
		console.error('获取Umami统计数据失败:', error);  
		['total-pageviews', 'total-visits', 'total-visitors'].forEach(id => {  
			const el = document.getElementById(id);  
			if (el) { el.textContent = '获取失败'; el.classList.add('text-red-500'); }  
		});  
	}  
}  
  
document.addEventListener('DOMContentLoaded', loadStats);  
  
if (window.swup) {  
	window.swup.hooks.on('page:view', loadStats);  
}  
</script>