---
import { Icon } from "astro-icon/components";

interface Props {
  info: string;
  class?: string;
}

const { info, class: className } = Astro.props;
---

{info && (
  <div class={`rounded-lg border border-[var(--primary)]/30 bg-[var(--primary)]/5 px-4 py-3 mb-5 ${className || ''}`}>
    <div class="flex items-start gap-3">
      <Icon name="material-symbols:info-outline" class="w-5 h-5 text-[var(--primary)] flex-shrink-0 mt-0.5" />
      <div class="text-sm text-neutral-700 dark:text-neutral-300 leading-relaxed">
        {info}
      </div>
    </div>
  </div>
)}
