<script define:vars={{ announcementText: announcementConfig.text }}>
    document.addEventListener('DOMContentLoaded', () => {
        const btn = document.getElementById('announcement-btn');
        const panel = document.getElementById('announcement-panel');
        const closeBtn = document.getElementById('announcement-close');
        const readBtn = document.getElementById('announcement-read-btn');
        const unreadBtn = document.getElementById('announcement-unread-btn');
        const float = document.getElementById('announcement-float');
        const dot = document.getElementById('announcement-dot');
        const readBtnText = document.getElementById('read-btn-text');
        const bodyEl = document.getElementById('announcement-body');
        
        // 处理换行符 \n
        if (bodyEl) {
            const formattedText = announcementText
                .replace(/\n/g, '<br>')
                .replace(/<a /g, '<a style="color: var(--primary); text-decoration: underline;" ');
            bodyEl.innerHTML = formattedText;
        }
        
        let isOpen = false;
        let isRead = false;
        
        function hashStr(str) {
            let hash = 0;
            for (let i = 0; i < str.length; i++) {
                const char = str.charCodeAt(i);
                hash = ((hash << 5) - hash) + char;
                hash = hash & hash;
            }
            return hash.toString(36);
        }
        
        const currentHash = hashStr(announcementText);
        const STORAGE_KEY = 'announcement_read_hash';
        
        function updateUI() {
            if (isRead) {
                dot?.classList.add('hidden');
                if (readBtnText) readBtnText.textContent = '已经读啦！';
                if (readBtn) {
                    readBtn.classList.add('read');
                    readBtn.disabled = true;
                }
                if (unreadBtn) unreadBtn.classList.remove('hidden');
            } else {
                dot?.classList.remove('hidden');
                if (readBtnText) readBtnText.textContent = '标记已读';
                if (readBtn) {
                    readBtn.classList.remove('read');
                    readBtn.disabled = false;
                }
                if (unreadBtn) unreadBtn.classList.add('hidden');
            }
        }
        
        function checkAnnouncementRead() {
            const storedHash = localStorage.getItem(STORAGE_KEY);
            if (storedHash === currentHash) {
                isRead = true;
            } else {
                isRead = false;
            }
            updateUI();
        }
        
        function markAsRead() {
            if (isRead) return;
            localStorage.setItem(STORAGE_KEY, currentHash);
            isRead = true;
            updateUI();
            isOpen = false;
            panel?.classList.remove('show');
        }
        
        function markAsUnread() {
            localStorage.removeItem(STORAGE_KEY);
            isRead = false;
            updateUI();
        }
        
        function showPanel() {
            isOpen = true;
            panel?.classList.add('show');
        }
        
        checkAnnouncementRead();
        
        if (!isRead) {
            showPanel();
        }
        
        btn?.addEventListener('click', () => {
            isOpen = !isOpen;
            panel?.classList.toggle('show', isOpen);
        });
        
        closeBtn?.addEventListener('click', () => {
            isOpen = false;
            panel?.classList.remove('show');
        });
        
        readBtn?.addEventListener('click', () => {
            markAsRead();
        });
        
        unreadBtn?.addEventListener('click', () => {
            markAsUnread();
        });
        
        document.addEventListener('click', (e) => {
            if (isOpen && !float?.contains(e.target)) {
                isOpen = false;
                panel?.classList.remove('show');
            }
        });
    });
</script>
